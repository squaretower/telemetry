# Copy to .env and fill in. Both domains must have A records pointing
# at the droplet's public IP before `docker compose up` (Caddy needs
# them resolvable to fetch Let's Encrypt certs).

SIGNOZ_DOMAIN=signoz.yourdomain.com
OTLP_DOMAIN=otel.yourdomain.com
ACME_EMAIL=mail@mackaygrant.com

# Long random string. This is what goes in the Modal secret as
# ST_TELEMETRY_API_KEY (Caddy expects it as `Authorization: Bearer <token>`).
# Generate:  openssl rand -hex 32
OTLP_BEARER_TOKEN=replace-me-openssl-rand-hex-32

# SigNoz UI login. Generate the hash with:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'your-password'
# Paste the resulting $2a$... hash below (single-quote it in the shell to
# avoid $-expansion; in this file leave it unquoted).
UI_BASICAUTH_USER=admin
UI_BASICAUTH_HASH=$2a$14$replace.with.actual.bcrypt.hash
